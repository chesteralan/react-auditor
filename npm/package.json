{
  "name": "react-auditor",
  "version": "0.1.9",
  "description": "A blazing-fast Rust CLI to scan JS/TS/React code for best practices, quality, and security issues",
  "bin": {
    "react-auditor": "./wrapper.js"
  },
  "scripts": {
    "prepack": "cargo build --release --manifest-path ../Cargo.toml && cp ../target/release/react-auditor ."
  },
  "repository": {
